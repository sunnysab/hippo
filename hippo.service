[Unit]
Description=Hippo WeChat Article Exporter Service
After=network.target postgresql.service

[Service]
Type=simple
User=sab
WorkingDirectory=/home/sab/hippo
ExecStart=/home/sab/hippo/.venv/bin/python -m hippo serve --host 0.0.0.0 --port 2000
Environment=HIPPO_LOG_FILE=/home/sab/hippo/logs/hippo.log
Environment=PYTHONUNBUFFERED=1
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
