# Core database connection required by both `hippo serve` and `hippo sync-worker`.
# This matches the currently detected local PostgreSQL deployment on this host.
HIPPO_PG_DSN=postgresql://postgres@127.0.0.1:5432/mp

# Optional runtime tuning.
HIPPO_LOG_LEVEL=WARNING
# HIPPO_PG_JIEBA_WARMUP=1
# HIPPO_PG_JIEBA_WARMUP_TEXT=hippo
# HIPPO_PG_POOL_MIN=1
# HIPPO_PG_POOL_MAX=8
# HIPPO_ENABLE_INPROCESS_SYNC=0

# Optional article HTML relay.
# HIPPO_ARTICLE_WORKER=
# HIPPO_ARTICLE_WORKER_PROXY=
# HIPPO_ARTICLE_MAX_CONNECTIONS=2

# Optional object storage for article images.
# HIPPO_S3_ENDPOINT=
# HIPPO_S3_BUCKET=
# HIPPO_S3_ACCESS_KEY=
# HIPPO_S3_SECRET_KEY=
# HIPPO_S3_REGION=
# HIPPO_S3_PREFIX=
